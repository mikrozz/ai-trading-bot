# Copy to ~/.config/trading-bot/binance_testnet.env (chmod 600) — NOT into git.

BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_BASE_URL=wss://stream.testnet.binance.vision

# Runtime
EXECUTION_MODE=testnet
MARKET_DATA_MODE=prod_public
SYMBOLS=BTCUSDT,ETHUSDT
LOG_LEVEL=INFO

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading
