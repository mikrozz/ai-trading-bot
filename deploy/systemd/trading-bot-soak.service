[Unit]
Description=AI Trading Bot testnet soak (LIMIT far + cancel + order sync)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/ai-trading-bot
Environment=PATH=/opt/ai-trading-bot/.venv/bin:/usr/local/bin:/usr/bin
EnvironmentFile=-/root/.config/trading-bot/binance_testnet.env
ExecStart=/opt/ai-trading-bot/.venv/bin/trading-bot --metrics-port 0 soak --symbol BTCUSDT --cycles 1 --pause 1.5
Nice=10
